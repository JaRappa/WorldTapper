{
  "expo": {
    "name": "WorldTapper",
    "slug": "WorldTapper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "worldtapper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "// Security Note": "These are client identifiers, not secrets. Server-side JWT validation ensures security.",
      "cognitoUserPoolId": "us-east-1_C8WRlcvHt",
      "cognitoClientId": "67pqn4aprvfq2e07nl03cg1o1f",
      "apiBaseUrl": "https://rdbffoe73a.execute-api.us-east-1.amazonaws.com/prod",
      "wsBaseUrl": "wss://jo6m4amkee.execute-api.us-east-1.amazonaws.com/prod"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.WorldTapper"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
